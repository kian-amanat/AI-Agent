{
  "name": "Auth API Backend (Login & Sign Up)",
  "project_type": "backend",
  "ready_for_user_review": false,
  "goal": "Design and implement a secure, scalable backend API for user login and sign up, following modern best practices and production-ready standards.",
  "tech_stack": {
    "runtime": "Bun 1.1+",
    "language": "TypeScript 5.5+",
    "framework": "Fastify 5.0",
    "orm": "Drizzle ORM 0.36+",
    "db": "PostgreSQL 17",
    "testing": "Vitest + Supertest",
    "tooling": "Bun, Drizzle CLI, Scalar, Pino, Zod",
    "ci_cd": "GitHub Actions + Docker",
    "monitoring": "Grafana + Prometheus"
  },
  "architecture": {
    "pattern": "Clean Architecture (Hexagonal)",
    "layers": [
      "Presentation (Routes/Controllers)",
      "Application (Use Cases/DTOs)",
      "Domain (Entities/Value Objects)",
      "Infrastructure (Repositories/DB/Auth)"
    ],
    "principles": [
      "Separation of Concerns",
      "SOLID Principles",
      "DRY",
      "Testability",
      "Scalability",
      "Security First",
      "Performance",
      "Maintainability"
    ]
  },
  "phases": [
    {
