{
  "name": "Email/Password Auth Backend",
  "project_type": "backend",
  "ready_for_user_review": true,
  "goal": "Develop a secure, production-ready backend API for user sign up and login using email and password authentication.",
  "tech_stack": {
    "runtime": "Bun 1.1+",
    "language": "TypeScript 5.5+",
    "framework": "Fastify 5.0",
    "orm": "Drizzle ORM 0.36+",
    "db": "PostgreSQL 17",
    "testing": "Vitest + Supertest",
    "tooling": "Bun, Drizzle CLI, Scalar, Pino, Zod",
    "ci_cd": "GitHub Actions + Docker",
    "monitoring": "Grafana + Prometheus"
  },
  "architecture": {
    "pattern": "Clean Architecture (Hexagonal)",
    "layers": [
      "Presentation (Routes/Controllers)",
      "Application (Use Cases/DTOs)",
      "Domain (Entities/Value Objects)",
      "Infrastructure (Repositories/DB/Auth)"
    ],
    "principles": [
      "Separation of Concerns",
      "SOLID Principles",
      "DRY",
      "Testability",
      "Scalability",
      "Security First",
      "Performance",
      "Maintainability"
    ]
  },
  "phases": [
    {
      "id": "phase-1",
      "name": "Foundation Setup",
      "description": "Initialize project, configure environment, and set up core dependencies.",
      "steps": [
        {
          "id": "step-1-1",
          "description": "Initialize Bun project with TypeScript strict mode.",
          "files": [
            "bun.lockb",
            "tsconfig.json",
            "package.json"
          ],
          "dependencies": [],
          "priority": "high",
          "estimated_time": "1h"
        },
        {
          "id": "step-1-2",
          "description": "Install and configure Fastify, Drizzle ORM, PostgreSQL, Zod, Pino, and Lucia Auth.",
          "files": [
            "src/app.ts",
            "src/server.ts",
            "src/config/env.ts",
            "src/config/database.ts"
          ],
          "dependencies": [
            "step-1-1"
          ],
          "priority": "high",
          "estimated_time": "2h"
        },
        {
          "id": "step-1-3",
          "description": "Set up environment variable validation using Zod.",
          "files": [
            "src/config/env.ts"
          ],
          "dependencies": [
            "step-1-2"
          ],
          "priority": "high",
          "estimated_time": "1h"
        },
        {
          "id": "step-1-4",
          "description": "Configure base error handling middleware.",
          "files": [
            "src/app.ts",
            "src/shared/infrastructure/error-handler.ts"
          ],
          "dependencies": [
            "step-1-2"
          ],
          "priority": "high",
          "estimated_time": "1h"
        }
      ]
    },
    {
      "id": "phase-2",
      "name": "Core Infrastructure & Auth",
      "description": "Implement authentication, RBAC, and security layers.",
      "steps": [
        {
          "id": "step-2-1",
          "description": "Design and implement user database schema with Drizzle ORM.",
          "files": [
            "src/db/schema/user.ts",
            "src/db/migrations/",
            "drizzle.config.ts"
          ],
          "dependencies": [
            "phase-1"
          ],
          "priority": "high",
          "estimated_time": "2h"
        },
        {
          "id": "step-2-2",
          "description": "Set up Lucia Auth for email/password authentication.",
          "files": [
            "src/plugins/auth.ts",
            "src/modules/auth/infrastructure/lucia.ts"
          ],
          "dependencies": [
            "step-2-1"
          ],
          "priority": "high",
          "estimated_time": "2h"
        },
        {
          "id": "step-2-3",
          "description": "Implement RBAC (basic user roles).",
          "files": [
            "src/modules/auth/domain/roles.ts"
          ],
          "dependencies": [
            "step-2-2"
          ],
          "priority": "medium",
          "estimated_time": "1h"
        },
        {
          "id": "step-2-4",
          "description": "Configure CORS, rate limiting, and security headers (helmet).",
          "files": [
            "src/plugins/cors.ts",
            "src/plugins/rate-limit.ts"
          ],
          "dependencies": [
            "phase-1"
          ],
          "priority": "high",
          "estimated_time": "1h"
        }
      ]
    },
    {
      "id": "phase-3",
      "name": "Domain Logic & Validation",
      "description": "Implement user registration and login logic with validation.",
      "steps": [
        {
          "id": "step-3-1",
          "description": "Create user entity, value objects, and repository interfaces.",
          "files": [
            "src/modules/auth/domain/user.entity.ts",
            "src/modules/auth/domain/user.value-object.ts",
            "src/modules/auth/infrastructure/user.repository.ts"
          ],
          "dependencies": [
            "step-2-1"
          ],
          "priority": "high",
          "estimated_time": "2h"
        },
        {
          "id": "step-3-2",
          "description": "Implement use cases for sign up and login.",
          "files": [
            "src/modules/auth/application/sign-up.usecase.ts",
            "src/modules/auth/application/login.usecase.ts"
          ],
          "dependencies": [
            "step-3-1"
          ],
          "priority": "high",
          "estimated_time": "2h"
        },
        {
          "id": "step-3-3",
          "description": "Set up Zod schemas for input validation (email, password).",
          "files": [
            "src/modules/auth/presentation/auth.schemas.ts"
          ],
          "dependencies": [
            "step-3-2"
          ],
          "priority": "high",
          "estimated_time": "1h"
        }
      ]
    },
    {
      "id": "phase-4",
      "name": "API Layer & Documentation",
      "description": "Expose RESTful endpoints for sign up and login, and document the API.",
      "steps": [
        {
          "id": "step-4-1",
          "description": "Implement Fastify routes and controllers for /signup and /login.",
          "files": [
            "src/modules/auth/presentation/auth.routes.ts",
            "src/modules/auth/presentation/auth.controller.ts"
          ],
          "dependencies": [
            "step-3-3"
          ],
          "priority": "high",
          "estimated_time": "2h"
        },
        {
          "id": "step-4-2",
          "description": "Define request/response DTOs.",
          "files": [
            "src/modules/auth/presentation/auth.dto.ts"
          ],
          "dependencies": [
            "step-4-1"
          ],
          "priority": "medium",
          "estimated_time": "1h"
        },
        {
          "id": "step-4-3",
          "description": "Set up OpenAPI documentation with Scalar.",
          "files": [
            "src/plugins/openapi.ts"
          ],
          "dependencies": [
            "step-4-1"
          ],
          "priority": "medium",
          "estimated_time": "1h"
        },
        {
          "id": "step-4-4",
          "description": "Add request logging with Pino.",
          "files": [
            "src/plugins/logger.ts"
          ],
          "dependencies": [
            "phase-1"
          ],
          "priority": "medium",
          "estimated_time": "1h"
        }
      ]
    },
    {
      "id": "phase-5",
      "name": "Testing & Deployment",
      "description": "Ensure code quality, test coverage, and prepare for deployment.",
      "steps": [
        {
          "id": "step-5-1",
          "description": "Write unit tests for use cases and domain logic.",
          "files": [
            "tests/unit/auth.usecase.test.ts"
          ],
          "dependencies": [
            "phase-3"
          ],
          "priority": "high",
          "estimated_time": "2h"
        },
        {
          "id": "step-5-2",
          "description": "Write integration and e2e tests for API endpoints.",
          "files": [
            "tests/integration/auth.routes.test.ts",
            "tests/e2e/auth.e2e.test.ts"
          ],
          "dependencies": [
            "phase-4"
          ],
          "priority": "high",
          "estimated_time": "2h"
        },
        {
          "id": "step-5-3",
          "description": "Add Dockerfile and docker-compose for local and production deployment.",
          "files": [
            "docker/Dockerfile",
            "docker/docker-compose.yml"
          ],
          "dependencies": [
            "phase-1"
          ],
          "priority": "medium",
          "estimated_time": "1h"
        },
        {
          "id": "step-5-4",
          "description": "Configure GitHub Actions for CI/CD pipeline.",
          "files": [
            ".github/workflows/ci.yml"
          ],
          "dependencies": [
            "step-5-3"
          ],
          "priority": "medium",
          "estimated_time": "1h"
        },
        {
          "id": "step-5-5",
          "description": "Set up monitoring with Grafana and Prometheus.",
          "files": [
            "docker/prometheus.yml",
            "docker/grafana.ini"
          ],
          "dependencies": [
            "step-5-3"
          ],
          "priority": "low",
          "estimated_time": "2h"
        }
      ]
    }
  ],
