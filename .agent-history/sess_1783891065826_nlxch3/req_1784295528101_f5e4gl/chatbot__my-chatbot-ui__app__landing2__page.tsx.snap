const HorizontalScrollSection = ({ title, cards }: { title: string; cards: { title: string; description: string }[] }) => {
  const containerRef = useRef<HTMLDivElement>(null);
  const { scrollYProgress } = useScroll({
    target: containerRef,
    offset: ['start end', 'end start'],
  });

  const scaleX = useSpring(scrollYProgress, {
    stiffness: 100,
    damping: 30,
    restDelta: 0.001,
  });

  const x = useTransform(scrollYProgress, [0, 1], ['0%', '-50%']);

  return (
    <section id={title.toLowerCase().replace(/\s+/g, '-')} className="relative py-24">
      <div className="mb-12 text-center">
        <h2 className="text-3xl font-bold text-white">{title}</h2>
      </div>
      <div ref={containerRef} className="relative h-[400px] w-full overflow-hidden">
        <motion.div style={{ x }} className="flex gap-6">
          {cards.map((card, index) => (
            <div key={index} className="h-[300px] w-[300px] flex-shrink-0">
              <GlowCard className="h-full">
                <h3 className="mb-2 text-xl font-semibold text-white">{card.title}</h3>
                <p className="text-gray-400">{card.description}</p>
              </GlowCard>
            </div>
          ))}
        </motion.div>
        <motion.div
          className="absolute bottom-0 left-0 right-0 h-1 bg-orange-500/50"
          style={{ scaleX }}
        />
      </div>
    </section>
  );
};

// --- Main Page Component ---

export default function Landing2Page() {
  const [mode, setMode] = useState<'ask' | 'auto'>('ask');

  const features = [
    { title: 'Multi-task decomposition', description: 'Give it a list of unrelated changes; it splits, plans, and executes each one, sequentially where files overlap so edits never race each other.' },
    { title: 'Persistent memory', description: 'Learns your project&apos;s patterns, preferences, and past fixes across sessions, stored locally in .kodo/memory.' },
    { title: 'One-click Undo', description: 'Every write is snapshotted before it happens; revert any change from local history in one click, no confirmation dance.' },
    { title: 'Ask mode vs Auto mode', description: 'Ask mode shows you the full plan and waits for approval before a single file changes; Auto mode applies changes and reports back.' },
    { title: 'Web search & page fetching', description: 'Looks up documentation or a reference site you name, extracts its design language — colors, layout, copy — and uses it as ground truth instead of guessing.' },
    { title: 'Design skills', description: 'A library of curated expert knowledge — UI/UX rules, animation recipes, layout archetypes — automatically pulled in for creative work, extensible with your own .md files.' },
    { title: 'Self-correcting on failure', description: 'When a generated change breaks, Kodo attempts a targeted "fix forward" repair using the exact error, rather than blindly retrying from scratch.' },
  ];

  const security = [
    { title: 'Local-first keys', description: 'Your API key and model config live in a local settings file on your machine; they&apos;re never sent to any Kodo-operated server — there isn&apos;t one, it&apos;s self-hosted.' },
    { title: 'Workspace sandboxing', description: 'Every file operation is path-resolved and checked against the workspace root; nothing can read or write outside your project directory.' },
    { title: 'Read-before-write enforcement', description: 'Kodo can only edit a file it has actually opened and read in that turn; it cannot blindly modify a file it never inspected.' },
    { title: 'Pre-write validation', description: 'Every patch is checked for syntax errors, structural JSX issues, duplicate imports/attributes, undefined components, and broken import paths before it&apos;s written.' },
    { title: 'Snapshot-before-write', description: 'The original state of every touched file is saved locally before any edit, which is what powers one-click Undo and complete peace of mind.' },
    { title: 'Verification gate', description: 'Typecheck, lint, and a real render check must pass — or the failure is reported honestly — before Kodo calls a task complete; it doesn&apos;t just claim success.' },
    { title: 'Bounded, transparent retries', description: 'If verification fails, Kodo retries with the exact error fed back, capped at a small number of attempts, with every step visible in the activity log — no silent infinite loops.' },
  ];

  return (
    <div className="min-h-screen bg-[#08080a] text-white">
            {/* Premium Liquid Glass Navbar */}
            <motion.nav
        initial={{ y: -100, opacity: 0 }}
        animate={{ y: 0, opacity: 1 }}
