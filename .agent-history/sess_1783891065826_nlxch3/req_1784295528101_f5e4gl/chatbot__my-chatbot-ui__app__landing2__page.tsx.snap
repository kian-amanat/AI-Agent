        className="fixed top-6 left-0 right-0 z-50 flex justify-center px-4"
      >
        <motion.div
          className={`
            relative flex items-center justify-between
            w-full max-w-4xl h-14
            rounded-full
            border border-white/[0.06]
            bg-white/[0.05]
