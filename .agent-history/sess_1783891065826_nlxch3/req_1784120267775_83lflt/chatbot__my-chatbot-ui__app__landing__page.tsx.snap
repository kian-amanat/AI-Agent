                    hidden: { opacity: 0, y: 20 },
                    visible: { opacity: 1, y: 0, transition: { duration: 0.8, ease: [0.22, 1, 0.36, 1] } }
                  }}
                  className="mb-6"
                >
                  <span className="inline-block py-1 px-3 rounded-full bg-white/[0.05] border border-white/[0.1] text-xs font-medium text-white/70 tracking-wider uppercase mb-6">
                    The Future of Development
                  </span>
                </motion.div>

                <motion.h1
                  variants={{
                    hidden: { opacity: 0, y: 20 },
                    visible: { opacity: 1, y: 0, transition: { duration: 0.8, ease: [0.22, 1, 0.36, 1] } }
                  }}
                  className="text-5xl md:text-7xl lg:text-8xl font-bold leading-[1.05] tracking-tight mb-8"
                >
                  Meet Kodo — the AI agent that{' '}
                  <span className="bg-gradient-to-r from-[#ff5e4d] via-[#ff8a3d] to-[#ffa03d] bg-clip-text text-transparent">
                    ships your code
                  </span>
                </motion.h1>

                <motion.p
                  variants={{
                    hidden: { opacity: 0, y: 20 },
                    visible: { opacity: 1, y: 0, transition: { duration: 0.8, ease: [0.22, 1, 0.36, 1] } }
                  }}
                  className="text-lg md:text-xl text-white/60 max-w-2xl mx-auto mb-12 leading-relaxed"
                >
                  Kodo explores your codebase, plans surgical changes, applies them safely, and verifies everything — while you stay in control.
                </motion.p>

                <motion.div
                  variants={{
                    hidden: { opacity: 0, y: 20 },
                    visible: { opacity: 1, y: 0, transition: { duration: 0.8, ease: [0.22, 1, 0.36, 1] } }
                  }}
                >
                  <button className="group relative overflow-hidden rounded-2xl bg-gradient-to-r from-[#ff5e4d] to-[#ff8a3d] py-4 px-10 text-base font-semibold text-white shadow-[0_0_40px_rgba(255,94,77,0.3)] transition-all duration-300 hover:shadow-[0_0_60px_rgba(255,94,77,0.5)] hover:scale-105 active:scale-95">
                    <div className="relative z-10 flex items-center gap-2">
                      <span>Start building</span>
