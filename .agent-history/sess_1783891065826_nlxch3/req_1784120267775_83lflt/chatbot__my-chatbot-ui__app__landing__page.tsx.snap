              className="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[80%] max-w-3xl h-[400px] rounded-2xl border border-white/[0.1] bg-white/[0.02] backdrop-blur-sm -z-10"
