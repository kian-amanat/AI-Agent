'use client';

import React, { useRef, useState, useEffect, useCallback } from 'react';
import { motion, useScroll, useSpring, useTransform, useMotionValue, useMotionTemplate, AnimatePresence } from 'framer-motion';
import {
  Search,
  ClipboardList,
  Wrench,
  ShieldCheck,
  Lock,
  History,
  ArrowUpRight,
  Menu,
  X,
  ChevronLeft,
  ChevronRight,
  Brain,
  Undo2,
  MessageSquare,
  Globe,
  Sparkles,
  AlertTriangle,
  CheckCircle2,
  FileCheck,
  Layers,
  Eye,
  RefreshCw,
} from 'lucide-react';
import Link from 'next/link';
import Image from 'next/image';
import { CinematicFooter } from '@/components/ui/motion-footer';
import GlowHorizonFM from '@/components/ui/glow-horizon';

// --- Reusable Components ---

/**
 * GlowCard
 * A reusable card component with a radial gradient highlight that follows the cursor.
 */
const GlowCard = ({ children, className = '' }: { children: React.ReactNode; className?: string }) => {
  const ref = useRef<HTMLDivElement>(null);
  const mouseX = useMotionValue(0);
  const mouseY = useMotionValue(0);

  const handleMouseMove = (e: React.PointerEvent<HTMLDivElement>) => {
    if (!ref.current) return;
    const rect = ref.current.getBoundingClientRect();
    mouseX.set(e.clientX - rect.left);
    mouseY.set(e.clientY - rect.top);
  };

  return (
    <motion.div
      ref={ref}
      className={`relative rounded-2xl border border-white/[0.06] bg-white/[0.03] p-8 group hover:shadow-[0_20px_40px_rgba(255,138,61,0.15)] transition-all duration-300 ${className}`}
      onPointerMove={handleMouseMove}
      style={{
        transformStyle: 'preserve-3d',
        transformOrigin: 'center',
      }}
    >
      {/* Glare Effect */}
      <motion.div
        className="pointer-events-none absolute inset-0 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-300"
        style={{
          background: useMotionTemplate`radial-gradient(600px circle at ${mouseX}px ${mouseY}px, rgba(255,255,255,0.14), transparent 40%)`,
        }}
      />
      <div className="relative z-10">{children}</div>
    </motion.div>
  );
};

/**
 * PipelineStep
 * Used for the workflow diagram and numbered pipeline cards.
 */
const PipelineStep = ({
  icon,
  title,
  description,
  index,
  isHorizontal = false,
}: {
  icon: React.ReactNode;
  title: string;
  description: string;
  index: number;
  isHorizontal?: boolean;
}) => {
  const container = {
    hidden: { opacity: 0, y: 20 },
    visible: {
      opacity: 1,
      y: 0,
      transition: {
        duration: 0.6,
        ease: [0.22, 1, 0.36, 1] as const,
      },
    },
  };

  return (
    <motion.div
      variants={container}
      className={`relative ${isHorizontal ? 'flex flex-col items-center text-center' : 'pl-20'}`}
    >
      {!isHorizontal && (
        <div className="absolute left-0 top-0 flex items-center justify-center w-12 h-12 rounded-xl bg-gradient-to-br from-[#ff5e4d] to-[#ff8a3d] shadow-lg shadow-[#ff5e4d]/20">
          {React.isValidElement(icon)
            ? React.cloneElement(icon as React.ReactElement<React.SVGProps<SVGSVGElement>>, { className: 'w-6 h-6 text-white' })
            : icon}
        </div>
      )}
      {isHorizontal && (
        <div className="w-16 h-16 rounded-2xl bg-gradient-to-br from-[#ff5e4d] to-[#ff8a3d] flex items-center justify-center shadow-lg shadow-[#ff5e4d]/20 mb-4">
          {React.isValidElement(icon)
            ? React.cloneElement(icon as React.ReactElement<React.SVGProps<SVGSVGElement>>, { className: 'w-8 h-8 text-white' })
            : icon}
        </div>
      )}
      <h3 className={`text-2xl font-semibold text-white mb-3 ${isHorizontal ? '' : ''}`}>{title}</h3>
      <p className="text-white/60 leading-relaxed text-lg">{description}</p>
    </motion.div>
  );
};

/**
 * HorizontalScrollSection
 * Implements scroll-jacking using framer-motion.
 * The wrapper gets its own ref, useScroll is scoped to that ref,
 * and useTransform maps that scoped progress to the row's horizontal position.
 */
const HorizontalScrollSection = ({ title, children }: { title: string; children: React.ReactNode }) => {
  const containerRef = useRef<HTMLDivElement>(null);
  const { scrollYProgress } = useScroll({
    target: containerRef,
  });
  const x = useTransform(scrollYProgress, [0, 1], ['0%', '-600%']);

  return (
    <section id={title.toLowerCase().replace(/\s+/g, '-')} className="relative h-[400vh] bg-[#08080a]">
      <div className="sticky top-0 h-screen overflow-hidden flex items-center">
        <div className="absolute inset-0 z-0">
          <GlowHorizonFM />
        </div>
        <div className="container mx-auto px-6 relative z-10">
          <motion.h2
            initial={{ opacity: 0, y: 20 }}
            whileInView={{ opacity: 1, y: 0 }}
            viewport={{ once: true }}
            transition={{ duration: 0.6, ease: [0.22, 1, 0.36, 1] }}
            className="text-4xl md:text-6xl font-bold text-center mb-12"
          >
            <span className="bg-gradient-to-r from-white to-white/60 bg-clip-text text-transparent">
              {title}
            </span>
          </motion.h2>
          <div className="relative w-full h-[400px]">
            <motion.div
              className="absolute top-0 left-0 flex h-full items-center"
              style={{ x }}
            >
              {children}
            </motion.div>
          </div>
        </div>
      </div>
    </section>
  );
};

// --- Navbar Component ---

const Navbar = () => {
  const [isScrolled, setIsScrolled] = useState(false);
  const [isMobileMenuOpen, setIsMobileMenuOpen] = useState(false);
  const [activeLink, setActiveLink] = useState('How it Works');
  const [mousePos, setMousePos] = useState({ x: 0, y: 0 });
  const [hoveredLink, setHoveredLink] = useState<string | null>(null);

  // Scroll detection
  useEffect(() => {
    const handleScroll = () => setIsScrolled(window.scrollY > 20);
    window.addEventListener('scroll', handleScroll);
    return () => window.removeEventListener('scroll', handleScroll);
  }, []);

  // Mouse tracking for glass highlight
  const handleMouseMove = (e: React.MouseEvent) => {
    const rect = e.currentTarget.getBoundingClientRect();
    setMousePos({
      x: e.clientX - rect.left,
      y: e.clientY - rect.top,
    });
  };

  const navItems = [
    { name: 'How it Works', href: '#how-it-works' },
    { name: 'Features', href: '#features' },
    { name: 'Security', href: '#security' },
    { name: 'Pricing', href: '#pricing' },
  ];

  return (
    <>
      {/* Mobile Menu Overlay */}
      <AnimatePresence>
        {isMobileMenuOpen && (
          <motion.div
            initial={{ opacity: 0, y: -20 }}
            animate={{ opacity: 1, y: 0 }}
            exit={{ opacity: 0, y: -20 }}
            className="fixed top-0 left-0 w-full h-screen z-[55] bg-[#08080a]/95 backdrop-blur-xl flex flex-col items-center justify-center gap-8 md:hidden"
          >
            {navItems.map((item) => (
              <motion.a
                key={item.name}
                href={item.href}
                onClick={() => setIsMobileMenuOpen(false)}
                className="text-2xl font-medium text-white/80 hover:text-[#ff5e4d] transition-colors"
                whileHover={{ scale: 1.05 }}
              >
                {item.name}
              </motion.a>
            ))}
            <Link
              href="/"
              onClick={() => setIsMobileMenuOpen(false)}
              className="mt-4 px-8 py-3 rounded-full bg-gradient-to-r from-[#ff5e4d] to-[#ff8a3d] text-white font-semibold shadow-lg shadow-[#ff5e4d]/20"
            >
              Open App
            </Link>
          </motion.div>
        )}
      </AnimatePresence>

      {/* Floating Capsule Navbar */}
      <motion.header
        initial={{ y: -100, opacity: 0 }}
        animate={{ y: 0, opacity: 1 }}
        transition={{ duration: 0.8, ease: [0.22, 1, 0.36, 1] }}
        className={`fixed top-6 left-0 right-0 z-50 flex justify-center px-4 transition-all duration-500 ${
          isScrolled ? 'top-4' : ''
        }`}
      >
        <motion.div
          className={`
            relative flex items-center justify-between
            w-full max-w-5xl h-16
            rounded-full
            border border-white/[0.12]
            bg-white/[0.03]
            backdrop-blur-2xl
            shadow-[0_8px_32px_rgba(0,0,0,0.12),_inset_0_1px_0_rgba(255,255,255,0.05)]
            overflow-hidden
            transition-all duration-500
          `}
          onPointerMove={handleMouseMove}
          whileHover={{
            backgroundColor: "rgba(255, 255, 255, 0.06)",
            borderColor: "rgba(255, 255, 255, 0.18)",
            boxShadow: "0 12px 40px rgba(0,0,0,0.15), inset 0 1px 0 rgba(255,255,255,0.08)",
            transition: { duration: 0.4, ease: [0.22, 1, 0.36, 1] }
          }}
        >
          {/* Liquid Glass Reflections */}
          <div className="absolute inset-0 pointer-events-none">
            <div className="absolute top-0 left-0 w-full h-[1px] bg-gradient-to-r from-transparent via-white/20 to-transparent" />
            <div className="absolute inset-0 bg-gradient-to-b from-white/[0.05] to-transparent opacity-50" />
          </div>

          {/* Cursor-following Glass Highlight */}
          <motion.div
            className="pointer-events-none absolute inset-0 opacity-30"
            style={{
              background: useMotionTemplate`radial-gradient(400px circle at ${mousePos.x}px ${mousePos.y}px, rgba(255,255,255,0.15), transparent 40%)`,
            }}
          />

          {/* Left: Logo */}
          <div className="flex items-center pl-2 pr-4 z-10">
            <Link href="/" className="flex items-center gap-3 group">
              <motion.div
                className="relative w-10 h-10 rounded-full bg-gradient-to-br from-[#ff5e4d] to-[#ff8a3d] flex items-center justify-center shadow-[0_0_20px_rgba(255,94,77,0.3)]"
                whileHover={{ scale: 1.1, rotate: 5 }}
                whileTap={{ scale: 0.95 }}
              >
                <Image src="/icon.png" alt="Kodo" width={24} height={24} className="object-contain relative z-10" />
                <div className="absolute inset-0 rounded-full bg-white/20 opacity-0 group-hover:opacity-100 transition-opacity" />
              </motion.div>
              <span className="text-white font-bold text-lg tracking-tight hidden sm:block">Kodo</span>
            </Link>
          </div>

          {/* Center: Navigation Links */}
          <div className="hidden md:flex items-center gap-1 px-2 z-10">
            {navItems.map((item) => (
              <Link
                key={item.name}
                href={item.href}
                onClick={() => setActiveLink(item.name)}
                onMouseEnter={() => setHoveredLink(item.name)}
                onMouseLeave={() => setHoveredLink(null)}
                className="relative px-4 py-2 text-sm font-medium text-white/60 hover:text-white transition-colors rounded-full group"
              >
                <span className="relative z-10">{item.name}</span>
                {/* Hover Background */}
                <span className="absolute inset-0 rounded-full bg-white/[0.05] opacity-0 group-hover:opacity-100 transition-opacity duration-300" />
                {/* Active Indicator */}
                {activeLink === item.name && (
                  <motion.span
                    layoutId="activeNav"
                    className="absolute inset-0 rounded-full border border-white/10 bg-white/[0.03]"
                    transition={{ type: "spring", stiffness: 300, damping: 30 }}
                  />
                )}
              </Link>
            ))}
          </div>

          {/* Right: CTA & Mobile Toggle */}
          <div className="flex items-center pl-2 pr-2 z-10 gap-2">
            <Link
              href="/"
              className="group relative flex items-center gap-2 px-5 py-2 rounded-full bg-gradient-to-r from-[#ff5e4d] to-[#ff8a3d] text-white text-sm font-semibold shadow-[0_0_20px_rgba(255,94,77,0.2)] hover:shadow-[0_0_30px_rgba(255,94,77,0.4)] transition-all duration-300 overflow-hidden"
            >
              <span className="relative z-10 flex items-center gap-2">
                Open App
                <ArrowUpRight className="w-3.5 h-3.5 opacity-70 group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-transform" />
              </span>
              <div className="absolute inset-0 bg-gradient-to-r from-[#ff8a3d] to-[#ff5e4d] opacity-0 group-hover:opacity-100 transition-opacity duration-300" />
            </Link>

            {/* Mobile Menu Button */}
            <button
              onClick={() => setIsMobileMenuOpen(!isMobileMenuOpen)}
              className="md:hidden p-2 text-white/60 hover:text-white transition-colors"
            >
              {isMobileMenuOpen ? <X className="w-5 h-5" /> : <Menu className="w-5 h-5" />}
            </button>
          </div>
        </motion.div>
      </motion.header>
    </>
  );
};

// --- Hero Section Component ---

const HeroSection = () => {
  const [mode, setMode] = useState<'ask' | 'auto'>('ask');

  return (
    <section className="min-h-screen flex items-center justify-center relative overflow-hidden pt-20">
      {/* GlowHorizonFM Background */}
      <div className="absolute inset-0 z-0">
        <GlowHorizonFM />
      </div>
      <div
        className="relative w-full h-full flex items-center justify-center"
        style={{ transformStyle: 'preserve-3d' }}
        onPointerMove={(e) => {
          const r = e.currentTarget.getBoundingClientRect();
          const x = (e.clientX - r.left) / r.width - 0.5;
          const y = (e.clientY - r.top) / r.height - 0.5;
          
          const rotateY = x * 10;
          const rotateX = -y * 10;

          const heroContent = document.getElementById('hero-content');
          if (heroContent) {
            heroContent.style.transform = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) scale(1.02)`;
          }
        }}
        onPointerLeave={() => {
          const heroContent = document.getElementById('hero-content');
          if (heroContent) {
            heroContent.style.transform = 'perspective(1000px) rotateX(0deg) rotateY(0deg) scale(1)';
          }
        }}
      >
        {/* Floating Glass Panel Mockup */}

        {/* Hero Content */}
        <div id="hero-content" className="relative z-10 max-w-5xl mx-auto px-6 text-center transition-transform duration-100 ease-out">
          <motion.div
            initial="hidden"
            animate="visible"
            variants={{
              hidden: {},
              visible: {
                transition: {
                  staggerChildren: 0.15,
                  delayChildren: 0.2,
                },
              },
            }}
          >
            <motion.div
              variants={{
                hidden: { opacity: 0, y: 20 },
                visible: { opacity: 1, y: 0, transition: { duration: 0.8, ease: [0.22, 1, 0.36, 1] } }
              }}
              className="mb-6"
            >
              <span className="inline-block py-1 px-3 rounded-full bg-white/[0.05] border border-white/[0.1] text-xs font-medium text-white/70 tracking-wider uppercase mb-6">
                The Future of Development
              </span>
            </motion.div>

            <motion.h1
              variants={{
                hidden: { opacity: 0, y: 20 },
                visible: { opacity: 1, y: 0, transition: { duration: 0.8, ease: [0.22, 1, 0.36, 1] } }
              }}
              className="text-5xl md:text-7xl lg:text-8xl font-bold leading-[1.05] tracking-tight mb-8"
            >
              Meet Kodo — the AI agent that{' '}
              <span className="bg-gradient-to-r from-[#ff5e4d] via-[#ff8a3d] to-[#ffa03d] bg-clip-text text-transparent">
                ships your code
              </span>
            </motion.h1>

            <motion.p
              variants={{
                hidden: { opacity: 0, y: 20 },
                visible: { opacity: 1, y: 0, transition: { duration: 0.8, ease: [0.22, 1, 0.36, 1] } }
              }}
              className="text-lg md:text-xl text-white/60 max-w-2xl mx-auto mb-12 leading-relaxed"
            >
              Kodo explores your codebase, plans surgical changes, applies them safely, and verifies everything — while you stay in control.
            </motion.p>

            <motion.div
              variants={{
                hidden: { opacity: 0, y: 20 },
                visible: { opacity: 1, y: 0, transition: { duration: 0.8, ease: [0.22, 1, 0.36, 1] } }
              }}
            >
              <div className="flex flex-col items-center gap-4">
                <button className="group relative overflow-hidden rounded-2xl bg-gradient-to-r from-[#ff5e4d] to-[#ff8a3d] py-4 px-10 text-base font-semibold text-white shadow-[0_0_40px_rgba(255,94,77,0.3)] transition-all duration-300 hover:shadow-[0_0_60px_rgba(255,94,77,0.5)] hover:scale-105 active:scale-95">
                  <div className="relative z-10 flex items-center gap-2">
                    <span>Start building</span>
                    <motion.span
                      initial={{ x: 0 }}
                      whileHover={{ x: 4 }}
                      transition={{ duration: 0.3, ease: 'easeOut' }}
                      className="inline-block"
                    >
                      →
                    </motion.span>
                  </div>
                  <div className="absolute inset-0 bg-white/20 opacity-0 group-hover:opacity-100 transition-opacity" />
                </button>

                {/* Mode Toggle */}
                <div className="flex items-center gap-4 bg-white/[0.03] border border-white/[0.06] rounded-full p-1 backdrop-blur-sm">
                  <button
                    onClick={() => setMode('ask')}
                    className={`px-4 py-1.5 rounded-full text-sm font-medium transition-all duration-300 ${
                      mode === 'ask' ? 'bg-white/10 text-white' : 'text-white/50 hover:text-white/80'
                    }`}
                  >
                    Ask mode
                  </button>
                  <button
                    onClick={() => setMode('auto')}
                    className={`px-4 py-1.5 rounded-full text-sm font-medium transition-all duration-300 ${
                      mode === 'auto' ? 'bg-white/10 text-white' : 'text-white/50 hover:text-white/80'
                    }`}
                  >
                    Auto mode
                  </button>
                </div>
                <p className="text-sm text-white/40">
                  {mode === 'ask' 
                    ? 'Review plans before execution' 
                    : 'Automatic changes with verification'}
                </p>
              </div>
            </motion.div>
          </motion.div>
        </div>
      </div>
    </section>
  );
};

// --- Features Section Component ---

const FeaturesSection = () => {
  const features = [
    {
      title: 'Multi-task decomposition',
      description: 'Give it a list of unrelated changes; it splits, plans, and executes each one, sequentially where files overlap so edits never race each other.',
    },
    {
      title: 'Persistent memory',
      description: 'Learns your project&apos;s patterns, preferences, and past fixes across sessions, stored locally in .kodo/memory.',
    },
    {
      title: 'One-click Undo',
      description: 'Every write is snapshotted before it happens; revert any change from local history in one click, no confirmation dance.',
    },
    {
      title: 'Ask mode vs Auto mode',
      description: 'Ask mode shows you the full plan and waits for approval before a single file changes; Auto mode applies changes and reports back.',
    },
    {
      title: 'Web search & page fetching',
      description: 'Looks up documentation or a reference site you name, extracts its design language — colors, layout, copy — and uses it as ground truth instead of guessing.',
    },
    {
      title: 'Design skills',
      description: 'A library of curated expert knowledge — UI/UX rules, animation recipes, layout archetypes — automatically pulled in for creative work, extensible with your own .md files.',
    },
    {
      title: 'Self-correcting on failure',
      description: 'When a generated change breaks, Kodo attempts a targeted "fix forward" repair using the exact error, rather than blindly retrying from scratch.',
    },
  ];

  return (
    <HorizontalScrollSection title="Features">
      {features.map((feature, index) => (
        <div key={feature.title} className="w-[80vw] flex-shrink-0 mx-4">
          <GlowCard className="h-80">
            <div className="h-full flex flex-col justify-between">
              <div>
                <h3 className="text-2xl font-semibold text-white mb-4">{feature.title}</h3>
                <p className="text-white/60 leading-relaxed">{feature.description}</p>
              </div>
              <div className="flex justify-end">
                <ArrowUpRight className="w-6 h-6 text-white/20 group-hover:text-[#ff5e4d] transition-colors" />
              </div>
            </div>
          </GlowCard>
        </div>
      ))}
    </HorizontalScrollSection>
  );
};

