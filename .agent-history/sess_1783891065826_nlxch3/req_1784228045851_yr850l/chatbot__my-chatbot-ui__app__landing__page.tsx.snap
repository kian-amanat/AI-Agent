// --- Security Section Component ---

const SecuritySection = () => {
  const securityFeatures = [
    {
      icon: Lock,
      title: 'Local-first keys',
      description: 'Your API key and model config live in a local settings file on your machine; they&apos;re never sent to any Kodo-operated server — there isn&apos;t one, it&apos;s self-hosted.',
    },
    {
      icon: ShieldCheck,
      title: 'Workspace sandboxing',
      description: 'Every file operation is path-resolved and checked against the workspace root; nothing can read or write outside your project directory.',
    },
    {
      icon: FileCheck,
      title: 'Read-before-write enforcement',
      description: 'Kodo can only edit a file it has actually opened and read in that turn; it cannot blindly modify a file it never inspected.',
    },
    {
      icon: CheckCircle2,
      title: 'Pre-write validation',
      description: 'Every patch is checked for syntax errors, structural JSX issues, duplicate imports/attributes, undefined components, and broken import paths before it&apos;s written.',
    },
    {
      icon: Layers,
      title: 'Snapshot-before-write',
      description: 'The original state of every touched file is saved locally before any edit, which is what powers one-click Undo and complete peace of mind.',
    },
    {
      icon: Eye,
      title: 'Verification gate',
      description: 'Typecheck, lint, and a real render check must pass — or the failure is reported honestly — before Kodo calls a task complete; it doesn&apos;t just claim success.',
    },
    {
      icon: RefreshCw,
      title: 'Bounded, transparent retries',
      description: 'If verification fails, Kodo retries with the exact error fed back, capped at a small number of attempts, with every step visible in the activity log — no silent infinite loops.',
    },
  ];

  return (
    <HorizontalScrollSection title="Security">
      {securityFeatures.map((feature, index) => (
        <div key={feature.title} className="w-[80vw] flex-shrink-0 mx-4">
          <GlowCard className="h-80">
            <div className="relative z-10">
              <div className="flex items-center gap-4 mb-6">
                <div className="w-12 h-12 rounded-xl bg-gradient-to-br from-[#ff5e4d] to-[#ff8a3d] flex items-center justify-center shadow-lg shadow-[#ff5e4d]/20">
                  <feature.icon className="w-6 h-6 text-white" />
                </div>
                <h3 className="text-xl font-semibold text-white">{feature.title}</h3>
              </div>
              <p className="text-white/60 leading-relaxed">{feature.description}</p>
            </div>
          </GlowCard>
        </div>
      ))}
    </HorizontalScrollSection>
  );
};

