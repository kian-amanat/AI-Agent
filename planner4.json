{
  "name": "Email/Password Auth Backend",
  "project_type": "backend",
  "ready_for_user_review": true,
  "goal": "Develop a secure, scalable backend API for user sign up and login using email and password authentication, following modern best practices and production standards.",
  "tech_stack": {
    "runtime": "Bun 1.1+",
    "language": "TypeScript 5.5+ (strict mode)",
    "framework": "Fastify 5.0",
    "orm": "Drizzle ORM 0.36+",
    "db": "PostgreSQL 17 (with pgvector enabled for future AI features)",
    "testing": "Vitest + Supertest",
    "tooling": "ESLint, Prettier, Drizzle CLI, Scalar (OpenAPI), Bunx",
    "ci_cd": "GitHub Actions + Docker",
    "monitoring": "Grafana + Prometheus"
  },
  "architecture": {
    "pattern": "Clean Architecture (Hexagonal)",
