      "Application (Use Cases/DTOs)",
      "Domain (Entities/Value Objects)",
      "Infrastructure (Repositories/External Services)",
      "Shared (Errors/Utils)"
    ],
    "principles": [
      "Separation of Concerns",
      "SOLID Principles",
      "DRY",
      "Testability",
      "Scalability",
      "Security First",
      "Performance",
      "Maintainability"
    ]
  },
